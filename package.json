{
  "name": "@u1f992/kvadrat",
  "version": "0.2.1",
  "main": "dist/index.js",
  "bin": {
    "kvadrat": "dist/cli.js"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "format:wasm": "devcontainer exec --workspace-folder . make -C wasm format",
    "tidy:wasm": "devcontainer exec --workspace-folder . make -C wasm tidy",
    "build:wasm": "devcontainer exec --workspace-folder . make -C wasm",
    "build:wasm:debug": "devcontainer exec --workspace-folder . make -C wasm debug",
    "clean:wasm": "devcontainer exec --workspace-folder . make -C wasm clean",
    "build:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "build:version": "npm run build:scripts && node scripts/version.ts",
    "build": "npm run build:wasm && npm run build:version && tsc && shx mkdir -p dist/wasm && shx cp src/wasm/core.js src/wasm/core.wasm dist/wasm/",
    "build:test": "tsc -p test/tsconfig.json --noEmit",
    "test": "npm run build && npm run build:test && node --test \"test/**/*.test.ts\""
  },
  "keywords": [],
  "homepage": "https://github.com/u1f992/kvadrat",
  "author": "Koutaro Mukai",
  "license": "MIT",
  "description": "Vectorizes bitmap images using layered recursive decomposition with z-ordered rectangle output.",
  "type": "module",
  "dependencies": {
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.84.1",
    "@types/node": "^22.19.15",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "shx": "^0.4.0",
    "typescript": "^6.0.2"
  }
}
