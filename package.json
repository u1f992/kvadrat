{
  "name": "@u1f992/kvadrat",
  "version": "0.2.1",
  "main": "dist/index.js",
  "bin": {
    "kvadrat": "dist/cli.js"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\"",
    "build:wasm": "devcontainer exec --workspace-folder . make -C wasm",
    "clean:wasm": "devcontainer exec --workspace-folder . make -C wasm clean",
    "build:version": "node -e \"const fs=require('node:fs');fs.writeFileSync('src/version.ts','export const VERSION=\\''+JSON.parse(fs.readFileSync('package.json',{encoding:'utf-8'})).version+'\\'',{encoding:'utf-8'})\"",
    "build": "npm run build:wasm && npm run build:version && npm run format && tsc && shx mkdir -p dist/wasm && shx cp src/wasm/core.js src/wasm/core.wasm dist/wasm/",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "keywords": [],
  "homepage": "https://github.com/u1f992/kvadrat",
  "author": "Koutaro Mukai",
  "license": "MIT",
  "description": "Vectorizes bitmap images by converting each pixel into polygons and merging regions with the same color.",
  "type": "module",
  "dependencies": {
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.84.1",
    "@types/node": "^22.13.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.40.0",
    "shx": "^0.4.0",
    "typescript": "^5.7.3"
  }
}
