{
  "name": "@u1f992/kvadrat",
  "version": "0.2.1",
  "main": "dist/index.js",
  "bin": {
    "kvadrat": "dist/cli.js"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "build:wasm": "devcontainer exec --workspace-folder . make -C wasm",
    "clean:wasm": "devcontainer exec --workspace-folder . make -C wasm clean",
    "build:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "build:version": "npm run build:scripts && node scripts/version.ts",
    "build": "npm run build:version && tsc",
    "build:test": "tsc -p test/tsconfig.json --noEmit",
    "test": "npm run build:test && node --test \"test/**/*.test.ts\""
  },
  "keywords": [],
  "homepage": "https://github.com/u1f992/kvadrat",
  "author": "Koutaro Mukai",
  "license": "MIT",
  "description": "Vectorizes bitmap images by converting each pixel into polygons and merging regions with the same color.",
  "type": "module",
  "dependencies": {
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.84.1",
    "@types/node": "^22.13.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.40.0",
    "shx": "^0.4.0",
    "typescript": "^5.7.3"
  }
}
